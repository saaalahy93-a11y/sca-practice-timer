{
  "name": "sca-practice-timer",
  "version": "1.0.0",
  "description": "MRCGP SCA practice timer — shareable PWA + iOS/Android via Capacitor",
  "private": true,
  "scripts": {
    "start": "npx --yes serve www -p 4173",
    "build": "node scripts/sync-www.js",
    "cap:sync": "npx cap sync",
    "ios": "npx cap open ios",
    "android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2"
  }
}
